# Bake our 5 patches on top of the working tq-hybrid-allow baseline so the
# image is consumable as a Nix package without bind-mount overlays.
#
# Patches (commit refs in /home/jasonbk/Projects/vllm on tq-hybrid-allow):
#   38237e347  xpu_moe: XPUExpertsWNA16 wired to xpu_fused_moe(is_int4=True)
#   7d571957a  int_wna16: register WNA16MoEBackend.XPU
#   dd8eb8bb2  inc: INCXPUMoEMethod (W4A16 sym int4 MoE on XPU)
#   ecda6a6f8  inc: auto-claim vanilla GPTQ sym int4 on XPU
#   fcc0c8365  inc: parse GPTQModel `dynamic` field
ARG BASE_IMAGE=vllm-xpu-tq:hybrid-noskip-4088d3dd0
FROM ${BASE_IMAGE}

ARG SITE=/opt/venv/lib/python3.12/site-packages/vllm

COPY model_executor/layers/fused_moe/experts/xpu_moe.py \
     ${SITE}/model_executor/layers/fused_moe/experts/xpu_moe.py
COPY model_executor/layers/fused_moe/oracle/int_wna16.py \
     ${SITE}/model_executor/layers/fused_moe/oracle/int_wna16.py
COPY model_executor/layers/quantization/inc.py \
     ${SITE}/model_executor/layers/quantization/inc.py

# Scrub host-leaked /nix/store paths in /workspace/vllm/.git/hooks/*.sample.
# The base image's COPY . . dragged in the upstream vllm git tree; on a
# NixOS build host, git's default sample hooks have shebangs pointing at
# /nix/store/<hash>-bash and /nix/store/<hash>-perl. Those files are
# never used at runtime, but their absolute store paths inside the layer
# trip Nix's fixed-output reference scanner when the resulting image is
# pulled via `dockerTools.pullImage`. Delete them — keeps the FOD clean.
RUN rm -f /workspace/vllm/.git/hooks/*.sample

LABEL org.opencontainers.image.source="https://github.com/vllm-project/vllm/tree/tq-hybrid-allow"
LABEL org.opencontainers.image.description="vLLM XPU + INC INT4 MoE + TurboQuant KV cache, baked from tq-hybrid-allow@fcc0c8365"
LABEL ai.intellm.upstream-base="vllm-xpu-tq:hybrid-noskip-4088d3dd0"
LABEL ai.intellm.tq-hybrid-allow-head="fcc0c8365"
