# intel/vllm:0.17.0-xpu provides Python + torch+xpu + IPEX, which is the
# whole substrate auto-round needs to run calibration forward passes on
# Intel Arc / Battlemage / etc. Pinned by content digest so the build is
# reproducible across hosts.
#
# Refresh with:
#   skopeo inspect docker://intel/vllm:0.17.0-xpu --format '{{.Digest}}'
FROM intel/vllm@sha256:e961d08135a6a8ef6decd857c6deab7a70eb00e19de21de54cbc0ce05d9a9f43

# Stable auto-round from PyPI. For source-dev runs, the wrapper script
# bind-mounts the host checkout at /workspace and sets PYTHONPATH=/workspace,
# which makes `import auto_round` resolve to the live source while the
# entry-point binaries (auto-round, auto-round-light, auto-round-best)
# stay pip-installed.
#
# transformers>=5.2.0 is required for qwen3_5_moe (Qwen3.5/3.6 MoE family);
# the base image ships 4.57.6, so we explicitly upgrade it. AutoRound's own
# floor is `transformers>=4.38`, so the bump is compatible.
#
# flash-linear-attention provides the gated-delta-rule and FusedRMSNormGated
# kernels used by qwen3_5_moe's hybrid (linear-attention) blocks. On XPU it
# runs through Intel's Triton port — verified with torch.xpu.is_available()
# and a successful import of fla.ops.gated_delta_rule.
#
# We deliberately skip causal-conv1d: it's CUDA-only (its setup.py looks for
# `bare_metal_version` from the CUDA toolkit and fails on XPU). The forward
# path in modeling_qwen3_5_moe falls back to F.silu(self.conv1d(...)) when
# causal_conv1d_fn is None, so correctness is preserved; the small conv is a
# negligible fraction of calibration time vs the gated-delta-rule prefill.
# Expect a residual "fast path is not available" warning at startup — that
# is the `is_fast_path_available = all(...)` check; the code still uses fla's
# fast kernels for the heavy ops via the per-attribute fallback chain.
RUN pip install --no-cache-dir auto-round 'transformers>=5.2.0' flash-linear-attention

WORKDIR /workspace
